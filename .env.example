DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/saturday_signal

# LLM provider for chat. Leave everything blank to run the deterministic
# offline composer. Set a key and the matching provider is auto-detected;
# set LLM_PROVIDER (mock | anthropic | openai) to force a choice.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional live sports data (CollegeFootballData.com)
CFBD_API_KEY=
